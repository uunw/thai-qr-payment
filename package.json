{
  "name": "thai-qr-payment-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Zero-dependency Thai QR Payment (EMVCo) toolkit — payload builder, QR encoder, SVG card renderer",
  "keywords": [
    "billpayment",
    "bot",
    "browser",
    "bun",
    "cloudflare-workers",
    "deno",
    "edge-runtime",
    "emv-qrcps",
    "emvco",
    "esm",
    "kbank",
    "kshop",
    "national-itmx",
    "node",
    "payment",
    "promptpay",
    "qr",
    "qr-code",
    "qrcode",
    "scb",
    "svg",
    "thai-qr",
    "thai-qr-payment",
    "thailand",
    "typescript",
    "zero-dependency"
  ],
  "homepage": "https://github.com/uunw/thai-qr-payment",
  "bugs": {
    "url": "https://github.com/uunw/thai-qr-payment/issues"
  },
  "license": "MIT",
  "author": {
    "name": "uunw",
    "url": "https://github.com/uunw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uunw/thai-qr-payment.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/uunw"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build && node scripts/compress-dist.mjs",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@rspack/cli": "^2.0.2",
    "@rspack/core": "^2.0.2",
    "@size-limit/esbuild": "^12.1.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "size-limit": "^12.1.0",
    "svgo": "^4.0.1",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
